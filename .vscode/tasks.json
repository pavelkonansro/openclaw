{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "check",
      "type": "shell",
      "command": "./scripts/check.sh",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "pytest",
      "type": "shell",
      "command": "pytest",
      "problemMatcher": []
    },
    {
      "label": "ruff",
      "type": "shell",
      "command": "ruff check .",
      "problemMatcher": []
    },
    {
      "label": "black-check",
      "type": "shell",
      "command": "black --check .",
      "problemMatcher": []
    },
    {
      "label": "js-check",
      "type": "shell",
      "command": "npm test && npm run lint",
      "problemMatcher": []
    }
  ]
}
